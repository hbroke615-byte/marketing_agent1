# Copy these into Railway → Project → Variables.
# Do NOT commit the real .env — Railway env vars replace it in production.

# === Azure AD app (for Microsoft Graph: Outlook + OneDrive) ===
CLIENT_ID=your_azure_ad_client_id
CLIENT_SECRET=your_azure_ad_client_secret
TENANT_ID=your_azure_ad_tenant_id

# === OpenAI ===
OPENAI_API_KEY=sk-...

# === Apollo CRM ===
APOLLO_API_KEY=

# === Apify (for LinkedIn lead scraping) ===
APIFY_API_TOKEN=

# === LinkedIn ===
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/your-handle/

# === Runtime tuning ===
POLL_INTERVAL=30
MARKETING_FOLDER_PATH=Marketing

# === Railway-specific: bind to all interfaces so the public router can reach us ===
APPROVAL_HOST=0.0.0.0
# PORT is auto-injected by Railway — do not set it manually.
