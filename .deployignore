# Documentation of what the Azure deployment package excludes.
# (Azure App Service does not natively read this file; package_for_azure.ps1
# is the source of truth for the exclusion list. Keep them in sync.)

# Local Python venvs (huge, regenerated by App Service from requirements.txt)
.venv/
ai/
__pycache__/
*.pyc

# Git internals
.git/
.gitignore

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Unused legacy/sandbox folders confirmed not referenced by main1.py
New folder/
static/
templates/

# Files not used at runtime
Proposal.pdf
Proposal1.pdf
analytics.db
manifest.xml
main.py
server.py
login.py

# Generated at runtime (no value in shipping them — regenerated on Azure)
apollo_crm.log
linkedin_dump.html

# Excluded by user request — Azure starts with empty data. Local files
# stay intact for local use.
apollo_contacts.json
marketing_contacts.json
marketing_campaigns.json
processed_linkedin_message_ids.json

# The .env file itself stays on the laptop; its values go into Azure
# App Service Configuration → Application settings instead.
.env

# Deployment artifacts (don't ship the zip inside the zip)
deploy.zip
deploy/
